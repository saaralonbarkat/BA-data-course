recode(Haifa="North",
`Tel Aviv` = "Center"))
localities_2023 %>% count(new_district)
t1 <- localities_2023 %>% mutate(
new_district = case_match(district_eng,
"Haifa" ~ "North",
"Tel Aviv" ~ "Center"
)
)
t1 %>% count(district_eng,new_district)
t1 <- localities_2023 %>% mutate(
new_district = case_match(district_eng,
"Haifa" ~ "North",
"Tel Aviv" ~ "Center",
.default = district_eng
)
)
t1 %>% count(district_eng,new_district)
localities_2023 <- localities_2023 %>%
mutate(new_rank = rank %>%
case_match(
c(1, 2, 3)    ~ "Low",
c(4, 5, 6, 7) ~ "Medium",
c(8, 9, 10)   ~ "High"
))
localities_2023 <- localities_2023 %>%
mutate(new_rank = socio_economic_rank %>%
case_match(
c(1, 2, 3)    ~ "Low",
c(4, 5, 6, 7) ~ "Medium",
c(8, 9, 10)   ~ "High"
))
