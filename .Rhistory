localities_2023 <- localities_2023 %>%
mutate(new_rank = socio_economic_rank %>%
case_match(
c(1, 2, 3)    ~ "Low",
c(4, 5, 6, 7) ~ "Medium",
c(8, 9, 10)   ~ "High"
))
localities_2023 %>% count(socio_economic_rank,new_rank)
localities_2023 <- localities_2023 %>%
mutate(arab_locality_1 = case_when(
percent_arab==100 ~ "Arab",
percent_arab==0 ~ "Jewish",
TRUE ~ "Mixed"
)
)
localities_2023 %>% count(arab_locality_1)
localities_2023 <- localities_2023 %>%
mutate(arab_locality_2 = case_when(
percent_arab>=90 ~ "Arab",
percent_arab<=10 ~ "Jewish",
TRUE ~ "Mixed"
)
)
localities_2023 %>% count(arab_locality_2)
