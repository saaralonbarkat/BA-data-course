library(tidyverse)
gapminder <- read_csv("https://raw.githubusercontent.com/saaralonbarkat/BA-data-course/refs/heads/main/data/gapminder/gapminder_modern_1952_2022.csv")
gapminder <- read_csv("https://raw.githubusercontent.com/saaralonbarkat/BA-data-course/refs/heads/main/data/gapminder/gapminder_modern_1952_2022.csv")
View(gapminder)
gapminder %>%
glimpse()
gapminder_2022 <- gapminder %>%
filter(year==2022)
gapminder_2022 %>%
select(country,
lifeExp)
gapminder_2022 <- gapminder %>%
filter(year==2022)
gapminder_2022 %>%
select(country,
lifeExp)
gapminder_2022 %>%
select(country,
lifeExp) %>%
arrange(lifeExp)
gapminder_2022 %>%
select(country,
lifeExp) %>%
arrange(lifeExp %>% desc())
gapminder_2022 %>%
select(lifeExp) %>%
summary()
gapminder_2022 %>%
select(lifeExp) %>%
summary()
gapminder_2022 %>%
select(country,
continent) %>%
arrange(continent)
gapminder_2022 %>%
count(continent) %>%
arrange(n %>% desc())
gapminder_2022 %>%
count(continent)
gapminder_2022 %>%
count(continent) %>%
arrange(n %>% desc())
gapminder_2022 %>%
ggplot(mapping = aes(x = continent)) +
geom_bar()
# Alternatively, you can do this and get the same result:
gapminder_2022 %>%
count(continent) %>%
ggplot(mapping = aes(x = continent, y=n)) +
geom_col()
gapminder_2022 %>%
ggplot(mapping=aes(x = lifeExp)) + # Here we need to define the variables to be used
geom_histogram() # now we need to define the type of plot (geometric dimension)
gapminder_2022 %>%
ggplot(aes(lifeExp))+
geom_histogram(binwidth = 5)
gapminder_2022 %>%
ggplot(mapping = aes(y = lifeExp)) +
geom_boxplot()
gapminder_2022 %>%
ggplot(mapping = aes(x = continent, y = lifeExp)) +
geom_boxplot()
# Tip: you can also sort categories
gapminder_2022 %>%
ggplot(aes(x=reorder(continent,lifeExp, FUN = median),y=lifeExp))+
geom_boxplot()
gapminder_2022 %>%
ggplot(mapping = aes(x = continent, y = lifeExp)) +
stat_summary(fun.y = "mean", geom = "point")
gapminder_2022 %>%
ggplot(mapping = aes(x = continent, y = lifeExp)) +
geom_boxplot()+
stat_summary(fun.y = "mean", geom = "point",color="red",size=2)
gapminder_2022 %>%
ggplot(mapping = aes(x = continent, y = lifeExp)) +
geom_boxplot()+
stat_summary(fun.y = "mean", geom = "point",color="red",size=2)
gapminder_2022 %>%
group_by(continent) %>%
summarise(mean_life_expectancy = lifeExp %>% mean(),
median_life_expectancy = lifeExp %>% median())
gapminder_2022 %>%
ggplot(aes(x = gdpPercap, y = lifeExp)) +
geom_point()
gapminder_2022 %>%
ggplot(aes(x = gdpPercap, y = lifeExp)) +
geom_point()+
geom_smooth()
#To change the default and use a linear trend/regression - add `method="lm"`
gapminder_2022 %>%
ggplot(aes(x = gdpPercap, y = lifeExp)) +
geom_point()+
geom_smooth(method = "lm")
gapminder_2022 %>% arrange(population)
gapminder_2022 <- gapminder %>%
filter(year==2022)
gapminder %>%
glimpse()
gapminder_2022 %>% arrange(pop)
View(gapminder_2022)
gapminder %>%
ggplot(mapping = aes(x = factor(year), y = lifeExp)) +
geom_boxplot()+
stat_summary(fun.y = "mean", geom = "point",color="red",size=2)
pop_sum %>%
ggplot(aes(x = year, y = pop)) +
geom_point()+
geom_line()
pop_sum <- gapminder %>%
group_by(year) %>%
summarise(pop=sum(pop))
pop_sum
gapminder %>%
ggplot(aes(x = gdpPercap, y = lifeExp)) +
geom_point() +
facet_grid(continent~year)
gapminder %>%
ggplot(aes(x = gdpPercap, y = lifeExp, color=continent, size = pop)) +
geom_point() +
facet_wrap(vars(year))
